FROM python:3.11-slim

RUN apt-get update && \
    apt-get install -y patch git && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Initialize git so 'git restore' and 'git clean' work for idempotency
RUN git init && \
    git config user.email "agent@resolver.local" && \
    git config user.name "Agent Resolver"

CMD ["tail", "-f", "/dev/null"]
