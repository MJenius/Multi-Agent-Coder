FROM python:3.11-slim-bookworm

RUN apt-get update && \
    apt-get install -y wget apt-transport-https patch git curl && \
    wget https://packages.microsoft.com/config/debian/12/packages-microsoft-prod.deb -O packages-microsoft-prod.deb && \
    dpkg -i packages-microsoft-prod.deb && \
    rm packages-microsoft-prod.deb && \
    apt-get update && \
    apt-get install -y dotnet-sdk-8.0 nodejs npm golang-go g++ default-jdk && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Initialize git so 'git restore' and 'git clean' work for idempotency
RUN git init && \
    git config user.email "agent@resolver.local" && \
    git config user.name "Agent Resolver"

CMD ["tail", "-f", "/dev/null"]
