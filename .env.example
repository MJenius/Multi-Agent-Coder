# ─── Ollama / LLM ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_SUPERVISOR_MODEL=llama3.2:latest
OLLAMA_CODER_MODEL=qwen2.5-coder:7b
OLLAMA_RESEARCHER_MODEL=llama3.2:latest
OLLAMA_CODER_NUM_PREDICT=1024

# ─── Graph ──────────────────────────────────────────────────────────────────
MAX_ITERATIONS=5

# ─── Sandbox ────────────────────────────────────────────────────────────────
SANDBOX_WORKSPACE_DIR=./sandbox_workspace

# ─── PostgreSQL (used by docker-compose) ────────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=langgraph_state
